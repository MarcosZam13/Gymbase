window.__timelines = window.__timelines || {};
var tl = gsap.timeline({ paused: true });

// ── S1: OWNER TITLE (0–2.5s) ────────────────────────────────
tl.fromTo('#os-glow1',  {opacity:0}, {opacity:1, duration:1.2, ease:'power2.out'}, 0.1);
